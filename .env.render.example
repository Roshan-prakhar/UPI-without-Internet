# Render environment variables for UPI Mesh backend
# Copy or import into Render dashboard. Adjust values as needed.

SPRING_PROFILES_ACTIVE=default
PORT=8080

# Database (optional: comment out if running with in-memory H2)
# DB_URL=jdbc:postgresql://db.example.com:5432/upimesh
# DB_USER=upimesh
# DB_PASSWORD=replace_me

# Logging
LOG_FILE=/var/log/upimesh/application.log

# Idempotency window configuration
IDEMPOTENCY_TTL_SECONDS=86400
PACKET_MAX_AGE_SECONDS=86400
